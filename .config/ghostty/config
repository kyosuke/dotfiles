# シェル。起動時に zellij の main セッションへ接続（無ければ作成）。
# zellij が default_shell の fish を起動する。GUI 起動では PATH を解決
# できないため zellij は絶対パスで指定する。
command = /Users/kyosuke/.cargo/bin/zellij attach -c main
shell-integration = fish

# タブはタイトルバーに表示
macos-titlebar-style = tabs

# テーマ
theme = "GitHub Dark Dimmed"

# 背景
background-opacity = 0.90
background-blur = true

# フォント
font-family = "PlemolJP35 Console NF"
font-size = 14

# 余白
window-padding-x = 12
window-padding-y = 8

# ウィンドウサイズ（縦幅最大）
window-height = 999
window-width = 100
