# シェル。起動時に zellij の main セッションへ接続（無ければ作成）。
# ログインシェル(zsh)経由で起動して PATH を解決してから zellij を exec する。
# これで zellij も default_shell の fish もインストール先をハードコードせず
# 名前解決でき、Intel/Apple Silicon どちらでも動く。
command = /bin/zsh --login -c "exec zellij attach -c main"
shell-integration = fish

# タブは使わない（多重化は zellij 側で行う）。
# transparent だと macOS ネイティブのタブ扱いになり、2タブ以上のときだけ
# タブバーが出る。zellij 運用では基本1タブなので表示されない。
macos-titlebar-style = transparent

# タブ関連のキーバインドを無効化（zellij 運用での誤爆やキー衝突を防ぐ）。
# ctrl 系はとくに unbind することで zellij や TUI 側へパススルーされる。
keybind = super+t=unbind
keybind = super+shift+]=unbind
keybind = super+shift+[=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind

# テーマ
theme = "GitHub Dark Dimmed"

# 背景
background-opacity = 0.90
background-blur = true

# フォント
font-family = "PlemolJP35 Console NF"
font-size = 14

# 余白
window-padding-x = 12
window-padding-y = 8

# ウィンドウサイズ（縦幅最大）
window-height = 999
window-width = 160
