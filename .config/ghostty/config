# シェル。起動時に zellij の main セッションへ接続（無ければ作成）。
# zellij が default_shell の fish を起動する。引数付き command は Ghostty が
# /bin/sh -c 経由で実行するため $HOME が展開される。GUI 起動の最小 PATH では
# zellij を名前解決できないので $HOME 起点のパスで指定する。
command = $HOME/.cargo/bin/zellij attach -c main
shell-integration = fish

# タブはタイトルバーに表示
macos-titlebar-style = tabs

# テーマ
theme = "GitHub Dark Dimmed"

# 背景
background-opacity = 0.90
background-blur = true

# フォント
font-family = "PlemolJP35 Console NF"
font-size = 14

# 余白
window-padding-x = 12
window-padding-y = 8

# ウィンドウサイズ（縦幅最大）
window-height = 999
window-width = 100
