{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(ls:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh project *)",
      "Bash(gh release *)",
      "Bash(gh repo view:*)",
      "Bash(gh status)",
      "Bash(rm -rf node_modules)",
      "Bash(rm -rf */node_modules)",
      "Read",
      "Glob",
      "Grep",
      "WebFetch(domain:www.pxgrid.com)",
      "WebFetch(domain:www.codegrid.net)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git checkout .:*)",
      "Bash(git clean:*)",
      "Bash(git branch -D:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh run delete:*)",
      "Bash(gh project delete:*)",
      "Bash(gh project field-delete:*)",
      "Bash(gh project item-delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release delete-asset:*)",
      "Bash(gh issue transfer:*)"
    ],
    "ask": [
      "Bash(gh pr close:*)",
      "Bash(gh release create:*)",
      "Bash(gh run cancel:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/kyosuke/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "codex@openai-codex": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "effortLevel": "xhigh",
  "advisorModel": "fable",
  "tui": "fullscreen",
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true
}
